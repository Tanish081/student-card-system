PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/school_performance
JWT_SECRET=replace_this_with_a_strong_secret
JWT_EXPIRES_IN=1d
DEFAULT_SCHOOL_ID=SCH001

# ── Production (set these in Render dashboard, not here) ─────────
# MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/school_performance?retryWrites=true&w=majority
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/school_performance?retryWrites=true&w=majority
# PUBLIC_BASE_URL=https://student-card-system-api.onrender.com
# CLIENT_URL=https://your-app.vercel.app
# PUBLIC_FRONTEND_URL=https://your-app.vercel.app
# ALLOW_VERCEL_PREVIEWS=true

# Durable upload storage (Cloudinary)
# CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
# CLOUDINARY_API_KEY=your_cloudinary_api_key
# CLOUDINARY_API_SECRET=your_cloudinary_api_secret
